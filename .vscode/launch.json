{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "api:app",
        "--reload"
      ],
      "jinja": true
    },
    {
      "name": "Celery",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "console": "integratedTerminal",
      "args": [
        "--app",
        "workers.tasks",
        "worker",
        "-l",
        "INFO"
      ],
      "jinja": true
    },
    {
      "type": "chrome",
      "request": "launch",
      "skipFiles": [
        "${workspaceFolder}/ui/node_modules/**/*.js"
      ],
      "name": "Launch Chrome",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/ui",
      "runtimeArgs": [
        "--remote-debugging-port=9222"
      ],
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Backends (FastApi and Celery)",
      "configurations": [
        "FastAPI",
        "Celery"
      ]
    },
    {
      "name": "All",
      "configurations": [
        "FastAPI",
        "Celery",
        "Launch Chrome"
      ]
    }
  ]
}
